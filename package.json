{
  "name": "chatgpt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-next-icons.mjs && next dev --hostname 0.0.0.0 --port 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
