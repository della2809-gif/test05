{
  "name": "chatgpt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vinext dev --host 0.0.0.0 --port 3010",
    "dev:next": "node scripts/clean-next-icons.mjs && next dev --hostname 0.0.0.0 --port 3010",
    "build": "vinext build",
    "build:next": "next build",
    "start": "vinext start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "check:secrets": "node scripts/check-secrets.mjs --history",
    "vercel-build": "npm run check:secrets && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.6.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.26",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "react-server-dom-webpack": "^19.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "^0.0.50",
    "vite": "^8.0.13",
    "vitest": "^4.1.5",
    "wrangler": "^4.92.0"
  },
  "type": "module"
}
